if {![info exists ::env(FOLK_HTTPS_SETUP_CHILD)]} {
    set tmp [exec mktemp -d]
    try {
        exec env FOLK_HTTPS_DIR=$tmp FOLK_HTTPS_SETUP_CHILD=1 FOLK_WEB_PORT=45273 ./folk test/https-setup-http.folk 2>@1
    } on error {e opts} {
        file delete -force $tmp
        error $e
    }
    file delete -force $tmp
    Exit! 0
}

Assert! when {
    source "builtin-programs/web/web.folk"
} with environment {}
source "builtin-programs/web/https-ca.folk"
source "builtin-programs/web/https-setup.folk"

set baseUrl "http://127.0.0.1:$::env(FOLK_WEB_PORT)"
set body ""
set started [clock milliseconds]
while true {
    try {
        set body [exec curl -sf "$baseUrl/setup/https"]
        break
    } on error e {
        if {[clock milliseconds] - $started > 5000} {
            error "HTTPS setup HTTP page did not become available: $e"
        }
        sleep 0.2
    }
}

assert {[string first "HTTP setup mode: certificates are missing" $body] >= 0}
assert {[string first "Generate HTTPS Certificates" $body] >= 0}
assert {[string first "Archive Folk HTTPS Certificates" $body] >= 0}
assert {[string first "Copy Terminal Command" $body] >= 0}
assert {[string first "Copy Removal Command" $body] >= 0}
assert {[string first "security add-trusted-cert -r trustRoot -p ssl -k" $body] >= 0}
assert {[string first "security delete-certificate -Z" $body] >= 0}
assert {[string first "login.keychain-db" $body] >= 0}
assert {[string first "Copy Stale CA Cleanup Command" $body] >= 0}
assert {[regexp {actionToken: "([^"]+)"} $body -> actionToken]}
set qr [exec curl -sf "$baseUrl/setup/https/qr.svg?text=hello"]
assert {[string first "<svg" $qr] >= 0}

set ca404 [exec curl -s -o - -w "\n%{http_code}" "$baseUrl/folk-ca.cer"]
assert {[string first "Visit /setup/https" $ca404] >= 0}
assert {[string match "*\n404" $ca404]}

set notifyBody "Wish to generate local HTTPS certificates with request http-tokenless-test"
exec curl -sf -X POST --data-binary $notifyBody "$baseUrl/"

set started [clock milliseconds]
while true {
    set results [Query! /someone/ claims HTTPS setup generation http-tokenless-test has status /status/ with /...options/]
    if {[llength $results] > 0 && [dict get [lindex $results end] status] eq "error"} {
        break
    }
    if {[clock milliseconds] - $started > 8000} {
        error "HTTPS setup tokenless generate rejection did not complete"
    }
    sleep 0.2
}

set notifyBody "Wish to generate local HTTPS certificates with request http-stale-test with token stale-token"
exec curl -sf -X POST --data-binary $notifyBody "$baseUrl/"

set started [clock milliseconds]
while true {
    set results [Query! /someone/ claims HTTPS setup generation http-stale-test has status /status/ with /...options/]
    if {[llength $results] > 0 && [dict get [lindex $results end] status] eq "error"} {
        break
    }
    if {[clock milliseconds] - $started > 8000} {
        error "HTTPS setup stale-token generate rejection did not complete"
    }
    sleep 0.2
}

set notifyBody "Wish to generate local HTTPS certificates with request http-test with token $actionToken"
exec curl -sf -X POST --data-binary $notifyBody "$baseUrl/"

set started [clock milliseconds]
while true {
    set results [Query! /someone/ claims HTTPS setup generation http-test has status /status/ with /...options/]
    if {[llength $results] > 0 && [dict get [lindex $results end] status] eq "success"} {
        break
    }
    if {[clock milliseconds] - $started > 8000} {
        error "HTTPS setup generate request did not complete"
    }
    sleep 0.2
}
foreach result [Query! /someone/ claims HTTPS setup generation http-test has status /status/ with /...options/] {
    assert {[dict get $result status] ne "error"}
}

set body [exec curl -sf "$baseUrl/setup/https"]
assert {[string first "Certificates are ready; restart Folk to enable HTTPS" $body] >= 0}
set status [exec curl -s -o /dev/null -w "%{http_code}" "$baseUrl/folk-ca.cer"]
assert {$status eq "200"}

set removeBody "Wish to remove local HTTPS certificates with request http-remove-tokenless-test"
exec curl -sf -X POST --data-binary $removeBody "$baseUrl/"

set started [clock milliseconds]
while true {
    set results [Query! /someone/ claims HTTPS setup removal http-remove-tokenless-test has status /status/ with /...options/]
    if {[llength $results] > 0 && [dict get [lindex $results end] status] eq "error"} {
        break
    }
    if {[clock milliseconds] - $started > 8000} {
        error "HTTPS setup tokenless remove rejection did not complete"
    }
    sleep 0.2
}

set removeBody "Wish to remove local HTTPS certificates with request http-remove-test with token $actionToken"
exec curl -sf -X POST --data-binary $removeBody "$baseUrl/"

set started [clock milliseconds]
while true {
    set results [Query! /someone/ claims HTTPS setup removal http-remove-test has status /status/ with /...options/]
    if {[llength $results] > 0 && [dict get [lindex $results end] status] eq "success"} {
        break
    }
    if {[clock milliseconds] - $started > 8000} {
        error "HTTPS setup remove request did not complete"
    }
    sleep 0.2
}
foreach result [Query! /someone/ claims HTTPS setup removal http-remove-test has status /status/ with /...options/] {
    assert {[dict get $result status] ne "error"}
}

set body [exec curl -sf "$baseUrl/setup/https"]
assert {[string first "HTTP setup mode: certificates are missing" $body] >= 0}
set ca404 [exec curl -s -o - -w "\n%{http_code}" "$baseUrl/folk-ca.cer"]
assert {[string match "*\n404" $ca404]}

Exit! 0
