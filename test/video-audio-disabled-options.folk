# test/video-audio-disabled-options.folk
# Open-time silent video options should not wait for audio hooks.

Assert! the video library is mock-video-lib
Assert! the GPU texture library is mock-texture-lib
Assert! the image library is mock-image-lib

source "builtin-programs/video/video.folk"

set ::videoAudioDisabledPage video-audio-disabled-page
set ::videoAudioDisabledTarget video-audio-disabled-target
set ::videoAudioDisabledAttempts 0

proc videoAudioDisabledFail {message} {
    puts $::realStderr "--- VIDEO AUDIO DISABLED OPTIONS TEST FAILED: $message ---"
    flush stderr
    Exit! 1
}

Hold! -on video-audio-disabled-options-test -key page-video-wish \
    Wish $::videoAudioDisabledPage plays video "test/test.mp4" with width 10cm audio false loop true
Hold! -on video-audio-disabled-options-test -key offside-video-wish \
    Wish to display a video right of $::videoAudioDisabledTarget "test/test.mp4" with width 10cm silent true loop true

proc pollVideoAudioDisabledOptions {} {
    if {$::videoAudioDisabledAttempts > 400} {
        videoAudioDisabledFail "Timeout waiting for silent playback wishes"
    }
    incr ::videoAudioDisabledAttempts

    set pageRequested false
    set pageFallbackMuted false
    foreach row [Query! /any/ wishes video playback $::videoAudioDisabledPage /path/ with /...options/] {
        set options [dict get $row options]
        if {![videoBoolOption $options audio true] && ![videoBoolOption $options mute false]} {
            set pageRequested true
        }
        if {[videoBoolOption $options mute false]} {
            set pageFallbackMuted true
        }
    }

    set offsideRequested false
    set offsideFallbackMuted false
    foreach row [Query! /any/ wishes video display playback /path/ beside $::videoAudioDisabledTarget right with /...options/] {
        set options [dict get $row options]
        if {[videoBoolOption $options silent false] && ![videoBoolOption $options mute false]} {
            set offsideRequested true
        }
        if {[videoBoolOption $options mute false]} {
            set offsideFallbackMuted true
        }
    }

    if {$pageRequested && !$pageFallbackMuted && $offsideRequested && !$offsideFallbackMuted} {
        puts $::realStderr "--- VIDEO AUDIO DISABLED OPTIONS TEST SUCCESS ---"
        flush stderr
        Exit! 0
    }

    after 5 pollVideoAudioDisabledOptions
}

after 0 pollVideoAudioDisabledOptions
after 10000 {
    videoAudioDisabledFail "Timeout"
}

vwait forever
